conda.enabled = true

executor {
    name   = 'local'
    cpus   = 18
    memory = '120 GB'
}

process {
    cpus   = { params.max_cpus ?: 16 }
    memory = { params.max_memory ?: '120 GB' }

    withName:INDEX_VCF              { cpus = 2; memory = '4 GB'  }
    withName:COLLECT_STUDY_SITES    { cpus = 1; memory = '8 GB'  }
    withName:CREATE_POP_FILE        { cpus = 1; memory = '2 GB'  }
    withName:SUMMARIZE_Q            { cpus = 1; memory = '4 GB'  }
    withName:PLOT_ANCESTRY          { cpus = 1; memory = '8 GB'  }
}
